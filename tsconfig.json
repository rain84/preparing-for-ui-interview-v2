{
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@course/styles": ["src/utilities/styles.module.css"],
			"@course/cx": ["src/utilities/utility.ts"],
			"@course/types": ["src/utilities/types.ts"],
			"@course/utils": ["src/utilities/utils.ts"]
		},
		"target": "ESNext",
		"lib": ["ES2022", "DOM", "DOM.Iterable", "ESNext"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["bun-types"],
		/* JSX */
		"jsx": "react-jsx",
		/* Emit */
		"noEmit": true,
		/* Interop */
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		/* Linting */
		"strict": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true
	},
	"include": ["src"],
	"exclude": []
}
